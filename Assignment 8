#include <iostream>
#include <fstream>
#include <string>
using namespace std;

struct Patient
{
    int id;
    string name;
    int age;
    string gender;
    string diagnosis;
};

int binarySearch(Patient p[], int size, int id)
{
    int left = 0;
    int right = size - 1;

    while(left <= right)
    {
        int mid = (left + right) / 2;

        if(p[mid].id == id)
            return mid;

        if(p[mid].id < id)
            left = mid + 1;
        else
            right = mid - 1;
    }

    return -1;
}

void sortPatients(Patient p[], int size)
{
    for(int i=0;i<size;i++)
    {
        for(int j=i+1;j<size;j++)
        {
            if(p[i].id > p[j].id)
            {
                Patient temp = p[i];
                p[i] = p[j];
                p[j] = temp;
            }
        }
    }
}

int main()
{
    Patient* patients = new Patient[100];
    int count = 0;
    int choice;

    ifstream in("patients.txt");

    if(in)
