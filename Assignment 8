            }
            else
                cout << "Patient not found\n";
        }

        else if(choice == 5)
        {
            ofstream out("patients.txt");

            for(int i=0;i<count;i++)
            {
                out << patients[i].id << ","
                    << patients[i].name << ","
                    << patients[i].age << " "
                    << patients[i].gender << ","
                    << patients[i].diagnosis << endl;
            }

